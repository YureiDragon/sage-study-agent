{
  "name": "ai-study-agent",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch scripts/dev.ts",
    "dev:ui": "vite --config vite.config.ts",
    "dev:bridge": "tsx watch scripts/dev.ts",
