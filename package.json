    "express": "^5.2.1",
    "lit": "^3.3.2",
    "marked": "^17.0.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@lit-labs/signals": "^0.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/ws": "^8.18.1",
    "signal-utils": "^0.21.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
